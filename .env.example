# Sadhna Health Care — Environment Variables (template)
#
# Copy this file to `.env` and fill in your real Supabase project credentials.
# `.env` is gitignored and must never be committed.
#
# Leaving these as the placeholder values runs the app in DEMO MODE
# (mock auth + on-device AsyncStorage persistence, no live backend).
#
# Find these in your Supabase dashboard → Project Settings → API.
# The anon key is a public client key (safe in the app bundle) but is still
# kept out of source control so each environment can use its own project.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
